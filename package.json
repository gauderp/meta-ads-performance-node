{
  "name": "@gauderp/meta-ads-performance-node",
  "version": "1.0.0",
  "type": "module",
  "description": "Paperclip plugin: Meta Ads performance monitoring with human-in-the-loop approvals",
  "scripts": {
    "build": "node ./esbuild.config.mjs",
    "dev": "node ./esbuild.config.mjs --watch",
    "test": "vitest run --config ./vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "files": [
    "dist",
    "migrations",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "keywords": [
    "paperclip",
    "paperclip-plugin",
    "meta-ads",
    "facebook-ads",
    "marketing-api"
  ],
  "author": "GAUD ERP <contato@gauderp.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gauderp/meta-ads-performance-node.git"
  },
  "homepage": "https://github.com/gauderp/meta-ads-performance-node#readme",
  "bugs": {
    "url": "https://github.com/gauderp/meta-ads-performance-node/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@paperclipai/plugin-sdk": "2026.517.0",
    "facebook-nodejs-business-sdk": "^22.0.3"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.0.8",
    "esbuild": "^0.27.3",
    "react": "^19.0.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
